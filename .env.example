# ─────────────────────────────────────────────────────────────────
#  Bulk Website Analyzer — Environment Variables
#  Copy this file to .env and fill in your values.
#  The .env file is gitignored — never commit your API keys!
# ─────────────────────────────────────────────────────────────────

# ── REQUIRED ──────────────────────────────────────────────────────

# Your Anthropic API key (get one at https://console.anthropic.com)
ANTHROPIC_API_KEY=your_anthropic_api_key_here


# ── AI MODEL (optional — defaults shown) ──────────────────────────

# claude-haiku-4-5-20251001    → cheapest/fastest  (~$0.25 per 500 sites)
# claude-sonnet-4-6  → most accurate    (~$3.00 per 500 sites)
CLAUDE_MODEL=claude-haiku-4-5-20251001

# Max tokens in Claude's response (per batch call)
CLAUDE_MAX_TOKENS=2048

# Number of sites sent to Claude in a single API call (1-20)
CLAUDE_BATCH_SIZE=10


# ── FETCHER (optional — defaults shown) ───────────────────────────

# Number of concurrent fetch workers
MAX_WORKERS=20

# Per-request timeout in seconds
REQUEST_TIMEOUT=15

# Minimum seconds between requests to the same domain
PER_DOMAIN_DELAY=2.0

# Max retry attempts per URL (exponential back-off: 1s, 2s, 4s)
MAX_RETRIES=3

# Max characters of body text to send to the AI (keeps costs down)
BODY_TEXT_LIMIT=3000


# ── OUTPUT (optional — defaults shown) ────────────────────────────

# Directory where result CSVs are saved
OUTPUT_DIR=results


# ── PHASE 2: GOOGLE SHEETS (optional) ────────────────────────────

# Path to your Google service account JSON key file
# See README for setup instructions
GOOGLE_SERVICE_ACCOUNT_FILE=path/to/service_account.json

# Your personal Google email — new sheets will be auto-shared here
# so results appear in YOUR Drive, not just the service account's
SHARE_SHEET_WITH=you@gmail.com


# ── PHASE 2: URL DISCOVERY (optional) ─────────────────────────────

# DuckDuckGo is the default provider — no key needed.
# For higher-volume discovery, use SerpAPI or Google CSE:

# SerpAPI key (https://serpapi.com)
SERPAPI_KEY=

# Google Custom Search Engine credentials
GOOGLE_CSE_KEY=
GOOGLE_CSE_ID=


# ── PHASE 3: APIFY PROXY (optional) ─────────────────────────────

# Route requests through Apify residential proxies to bypass
# Cloudflare and other anti-bot protections.
# Sign up at https://apify.com → Settings → Integrations → API token

# Enable proxy (set to true, 1, or yes to activate)
USE_PROXY=false

# Your Apify API token
APIFY_API_TOKEN=

# Proxy group: RESIDENTIAL (best for Cloudflare) or SHADER (cheaper datacenter)
APIFY_PROXY_GROUP=RESIDENTIAL
