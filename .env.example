# ─────────────────────────────────────────────────────────────────
#  Bulk Website Analyzer — Environment Variables
#  Copy this file to .env and fill in your values.
#  The .env file is gitignored — never commit your API keys!
# ─────────────────────────────────────────────────────────────────

# ── REQUIRED ──────────────────────────────────────────────────────

# Your Anthropic API key (get one at https://console.anthropic.com)
ANTHROPIC_API_KEY=your_anthropic_api_key_here


# ── AI MODEL (optional — defaults shown) ──────────────────────────

# claude-haiku-4-5-20251001    → cheapest/fastest  (~$0.25 per 500 sites)
# claude-sonnet-4-6  → most accurate    (~$3.00 per 500 sites)
CLAUDE_MODEL=claude-haiku-4-5-20251001

# Max tokens in Claude's response (per batch call)
CLAUDE_MAX_TOKENS=2048

# Number of sites sent to Claude in a single API call (1-20)
CLAUDE_BATCH_SIZE=10


# ── FETCHER (optional — defaults shown) ───────────────────────────

# Number of concurrent fetch workers
MAX_WORKERS=20

# Per-request timeout in seconds
REQUEST_TIMEOUT=15

# Minimum seconds between requests to the same domain
PER_DOMAIN_DELAY=2.0

# Max retry attempts per URL (exponential back-off: 1s, 2s, 4s)
MAX_RETRIES=3

# Max characters of body text to send to the AI (keeps costs down)
BODY_TEXT_LIMIT=3000


# ── OUTPUT (optional — defaults shown) ────────────────────────────

# Directory where result CSVs are saved
OUTPUT_DIR=results


# ── PHASE 2: URL DISCOVERY (leave blank until Phase 2) ────────────

# SerpAPI key (https://serpapi.com) — for auto URL discovery
SERPAPI_KEY=

# Google Custom Search Engine (CSE) credentials
GOOGLE_CSE_KEY=
GOOGLE_CSE_ID=
